# Copy to .env and fill in. Loaded automatically for local runs.
# In GitHub Actions these come from repo Secrets/Variables instead.

# --- LLM (required) -------------------------------------------------------
# Get a free key at https://build.nvidia.com (Login -> Generate API Key).
LLM_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Provider is OpenAI-compatible, so any of these can be swapped freely.
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=z-ai/glm-5.2

# --- Optional -------------------------------------------------------------
# Max videos to summarize per run. New videos are always *discovered* and queued
# regardless of this; the cap only limits how many get summarized each run, to
# avoid bursts that trip YouTube/LLM rate limits. 0 = unlimited (drain the whole
# queue every run — fine in steady state, risky on a big backlog + free tier).
MAX_VIDEOS_PER_RUN=15

# Netscape-format cookies file, if YouTube starts blocking the runner/your IP.
# Export with a browser extension, then: YTDLP_COOKIES=./cookies.txt
YTDLP_COOKIES=

# Local only: read cookies directly from a logged-in browser — no export needed.
# e.g. chrome, firefox, safari, brave, edge. Ignored if YTDLP_COOKIES is set.
YTDLP_COOKIES_FROM_BROWSER=

# Residential proxy for YouTube traffic ONLY (bypasses the datacenter bot-check).
# The LLM call does NOT go through this, so your metered GB stays tiny.
# Option A: a full proxy URL for any provider:
# e.g. http://user:pass@host:port  (Decodo, IPRoyal, any provider)
YT_PROXY=

# Option B (Decodo): just the credentials. Host/port default to Decodo's gateway
# and rotate across sticky ports 10001-10010 (≈10 residential IPs) automatically.
DECODO_USERNAME=
DECODO_PASSWORD=
# Optional overrides:
# DECODO_HOST=gate.decodo.com
# DECODO_PORT=10001-10010     # single port or an inclusive range

# Max output tokens for a summary (higher = longer / more detailed, but slower
# and more likely to get dropped by the free endpoint).
LLM_MAX_TOKENS=8192

# Reasoning models (like GLM-5.2) run a hidden "thinking" pass that is slow and
# unnecessary for summarization; it's disabled by default. Set to 1 to keep it.
LLM_THINKING=

# Set to 1/true to include YouTube Shorts (skipped by default).
INCLUDE_SHORTS=

# Skip videos longer than this many minutes in feed runs (marathons/courses
# blow the token budget and don't summarize well). 0 disables. --video ignores it.
MAX_VIDEO_MINUTES=90
